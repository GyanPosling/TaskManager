<?xml version="1.0"?>
<!DOCTYPE suppressions [
    <!ELEMENT suppressions (suppress*)>
    <!ELEMENT suppress EMPTY>
    <!ATTLIST suppress
        checks CDATA #REQUIRED
        files CDATA #REQUIRED
        id CDATA #IMPLIED
        lines CDATA #IMPLIED
        columns CDATA #IMPLIED>
]>
<suppressions>
    <suppress checks="FileTabCharacter" files=".*"/>
    <suppress checks=".*Javadoc.*" files=".*"/>
    <suppress checks="AtclauseOrder|NonEmptyAtclauseDescription|RequireEmptyLineBeforeBlockTagGroup"
              files=".*"/>
</suppressions>
